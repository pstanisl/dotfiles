# Performance profiling of zsh
# Enable with: ZSH_PROFILE=1 zsh -i -c exit
if [[ -n "${ZSH_PROFILE:-}" ]]; then
  zmodload zsh/zprof
fi

# Oh-My-Zsh update settings
zstyle ':omz:update' mode reminder
zstyle ':omz:update' frequency 30

# Source modular zsh configs
[[ -f ~/.zsh/aliases.zsh ]] && source ~/.zsh/aliases.zsh
[[ -f ~/.zsh/brew.zsh ]] && source ~/.zsh/brew.zsh
[[ -f ~/.zsh/python.zsh ]] && source ~/.zsh/python.zsh
#[[ -f ~/.zsh/conda.zsh ]] && source ~/.zsh/conda.zsh
[[ -f ~/.zsh/nvm.zsh ]] && source ~/.zsh/nvm.zsh
[[ -f ~/.zsh/zsh.zsh ]] && source ~/.zsh/zsh.zsh

# Oh-My-Zsh
export ZSH="$HOME/.oh-my-zsh"

plugins=(
	git
	python
	brew
	macos
	zsh-autosuggestions
)

source $ZSH/oh-my-zsh.sh

# Cached init scripts — sourcing pre-generated static files instead of running
# `eval "$(tool init zsh)"` on every shell start. Each eval spawns a subprocess
# (~30-50ms each), which adds up significantly.
#
# To regenerate after updating any of these tools, run:
#   fzf --zsh > ~/.zsh/cache/fzf.zsh
#   starship init zsh > ~/.zsh/cache/starship.zsh
#   atuin init zsh > ~/.zsh/cache/atuin.zsh
#   zoxide init zsh > ~/.zsh/cache/zoxide.zsh
source ~/.zsh/cache/fzf.zsh
source ~/.zsh/cache/starship.zsh

if [[ -f /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]]; then
    source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi

. "$HOME/.atuin/bin/env"
source ~/.zsh/cache/atuin.zsh
source ~/.zsh/cache/zoxide.zsh

if [[ -n "${ZSH_PROFILE:-}" ]]; then
  zprof
fi
